# Analytics & Aggregation Queries
# Shows sum/avg/min/max/count with conditions
# codong run 12-analytics-aggregation.cod

db.connect("sqlite:///orders.db")

db.query("CREATE TABLE IF NOT EXISTS orders (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    customer TEXT,
    amount REAL,
    product TEXT,
    region TEXT,
    order_date TEXT
)", [])

# Seed if empty
if db.count("orders", "1=1") == 0 {
    rows = [
        ["Alice", 120.5, "Widget A", "North", "2026-01-10"],
        ["Bob",   340.0, "Widget B", "South", "2026-01-15"],
        ["Alice", 89.0,  "Widget A", "North", "2026-02-01"],
        ["Carol", 450.0, "Widget C", "East",  "2026-02-14"],
        ["Bob",   220.0, "Widget A", "South", "2026-03-01"],
        ["Alice", 560.0, "Widget B", "North", "2026-03-20"]
    ]
    for r in rows {
        db.query("INSERT INTO orders (customer, amount, product, region, order_date) VALUES (?,?,?,?,?)", r)
    }
}

total   = db.sum("orders", "amount", "1=1")
average = db.avg("orders", "amount", "1=1")
highest = db.max("orders", "amount", "1=1")
lowest  = db.min("orders", "amount", "1=1")
count   = db.count("orders", "1=1")

print("=== Order Analytics ===")
print("Total orders : {count}")
print("Total revenue: ${total}")
print("Average order: ${average}")
print("Largest order: ${highest}")
print("Smallest order: ${lowest}")

north_total = db.sum("orders", "amount", "region = 'North'")
print("North revenue: ${north_total}")

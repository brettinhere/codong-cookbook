# ETL Pipeline — Extract, Transform, Load
# Reads from API → transforms → loads to SQLite with deduplication
# codong run 49-pipeline-etl.cod

db.connect("sqlite:///etl.db")
db.query("CREATE TABLE IF NOT EXISTS posts (
    id INTEGER PRIMARY KEY,
    title TEXT,
    body TEXT,
    user_id INTEGER,
    word_count INTEGER,
    category TEXT,
    imported_at TEXT
)", [])

# Extract
print("Extracting from API...")
resp = http.get("https://jsonplaceholder.typicode.com/posts?_limit=20")
raw_posts = resp.json

print("Extracted {raw_posts.len()} posts")

# Transform
fn categorize(title) {
    title_lower = title.lower()
    if title_lower.contains("error") or title_lower.contains("problem") { return "issue" }
    if title_lower.contains("qui") or title_lower.contains("est") { return "general" }
    if title_lower.contains("nemo") or title_lower.contains("nam") { return "reference" }
    return "uncategorized"
}

transformed = raw_posts.map(fn(post) {
    return {
        id:          post.id,
        title:       post.title.trim(),
        body:        post.body.trim(),
        user_id:     post.userId,
        word_count:  post.body.split(" ").len(),
        category:    categorize(post.title),
        imported_at: time.now().format("YYYY-MM-DD HH:mm:ss")
    }
})

# Load (upsert)
print("Loading {transformed.len()} records...")
new_count = 0
skip_count = 0

for post in transformed {
    existing = db.query("SELECT id FROM posts WHERE id = ?", [post.id])
    if existing.len() > 0 {
        skip_count = skip_count + 1
        continue
    }
    db.query("INSERT INTO posts (id, title, body, user_id, word_count, category, imported_at) VALUES (?,?,?,?,?,?,?)",
        [post.id, post.title, post.body, post.user_id, post.word_count, post.category, post.imported_at])
    new_count = new_count + 1
}

print("\n=== ETL Summary ===")
print("New records  : {new_count}")
print("Skipped      : {skip_count}")
print("Total in DB  : {db.count('posts', '1=1')}")

avg_words = db.avg("posts", "word_count", "1=1")
print("Avg word count: {avg_words}")

categories = db.query("SELECT category, COUNT(*) as count FROM posts GROUP BY category", [])
print("By category:")
for c in categories {
    print("  {c.category}: {c.count}")
}

# Password Hashing with bcrypt
# Hash, verify, and migrate passwords securely
# codong run 71-password-hashing.cod

fn demo_bcrypt() {
    password = "my$ecretP@ssword"

    # Hash (cost factor 12 — recommended for 2024+)
    hash = crypto.bcrypt(password, cost: 12)
    print("Original : {password}")
    print("Hashed   : {hash}")
    print("Length   : {hash.len()} chars\n")

    # Verify — correct password
    ok = crypto.bcrypt_verify(password, hash)
    print("Verify correct  : {ok}")

    # Verify — wrong password
    bad = crypto.bcrypt_verify("wrongpassword", hash)
    print("Verify wrong    : {bad}\n")

    # Each hash is unique (different salt)
    hash2 = crypto.bcrypt(password, cost: 12)
    print("Different hashes (same password): {hash != hash2}")
}

fn demo_password_policies() {
    passwords = ["short", "allowercase", "NoSpecial1", "G00d!Pass#", "123456", "P@ssw0rd!"]

    fn check_policy(p) {
        errors = []
        if p.len() < 8          { errors.push("too short (min 8)") }
        if !p.match("[A-Z]")    { errors.push("needs uppercase") }
        if !p.match("[0-9]")    { errors.push("needs digit") }
        if !p.match("[!@#$%^&]"){ errors.push("needs special char") }
        return errors
    }

    print("── Password Policy Check ──────────────")
    passwords.each(fn(p) {
        errs = check_policy(p)
        if errs.len() == 0 {
            print("  ✓  \"{p}\"")
        } else {
            print("  ✗  \"{p}\" — {errs.join(', ')}")
        }
    })
}

fn demo_migration() {
    # Simulate migrating old MD5 hashes to bcrypt on next login
    old_md5_hash = crypto.md5("oldpassword")
    print("\n── Hash Migration ─────────────────────")
    print("Old MD5 : {old_md5_hash}")

    fn login(input_password, stored_hash, hash_type) {
        if hash_type == "md5" {
            if crypto.md5(input_password) == stored_hash {
                # Rehash with bcrypt
                new_hash = crypto.bcrypt(input_password, cost: 12)
                print("Migrated to bcrypt: {new_hash.slice(0, 30)}...")
                return {ok: true, new_hash: new_hash, new_type: "bcrypt"}
            }
        }
        if hash_type == "bcrypt" {
            return {ok: crypto.bcrypt_verify(input_password, stored_hash)}
        }
        return {ok: false}
    }

    result = login("oldpassword", old_md5_hash, "md5")
    print("Login result: ok={result.ok}")
}

demo_bcrypt()
demo_password_policies()
demo_migration()

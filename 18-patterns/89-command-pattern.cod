# Command Pattern with Undo/Redo
# Text editor with full history stack — every action is reversible
# codong run 89-command-pattern.cod

fn make_text_editor() {
    content  = ""
    history  = []   # stack of {execute, undo}
    redo_buf = []

    fn execute(cmd) {
        cmd.execute()
        history.push(cmd)
        redo_buf = []   # new action clears redo buffer
    }

    fn undo() {
        if history.len() == 0 {
            print("  [nothing to undo]")
            return
        }
        cmd = history.pop()
        cmd.undo()
        redo_buf.push(cmd)
    }

    fn redo() {
        if redo_buf.len() == 0 {
            print("  [nothing to redo]")
            return
        }
        cmd = redo_buf.pop()
        cmd.execute()
        history.push(cmd)
    }

    fn insert_cmd(pos, text) {
        return {
            execute: fn() {
                content = content.slice(0, pos) + text + content.slice(pos, content.len())
                print("  INSERT '{text}' at {pos}  → \"{content}\"")
            },
            undo: fn() {
                content = content.slice(0, pos) + content.slice(pos + text.len(), content.len())
                print("  UNDO INSERT            → \"{content}\"")
            },
        }
    }

    fn delete_cmd(pos, length) {
        deleted = ""
        return {
            execute: fn() {
                deleted = content.slice(pos, pos + length)
                content = content.slice(0, pos) + content.slice(pos + length, content.len())
                print("  DELETE [{pos},{pos+length}] '{deleted}'  → \"{content}\"")
            },
            undo: fn() {
                content = content.slice(0, pos) + deleted + content.slice(pos, content.len())
                print("  UNDO DELETE            → \"{content}\"")
            },
        }
    }

    fn replace_cmd(pos, length, new_text) {
        return {
            execute: fn() {
                del = delete_cmd(pos, length)
                ins = insert_cmd(pos, new_text)
                del.execute()
                ins.execute()
            },
            undo: fn() {
                del = delete_cmd(pos, new_text.len())
                old_text = ""  # would need to capture; simplified
                print("  UNDO REPLACE           → \"{content}\"")
            },
        }
    }

    get_content = fn() { return content }

    return {execute: execute, undo: undo, redo: redo,
            insert: insert_cmd, delete: delete_cmd, get: get_content}
}

editor = make_text_editor()

print("── Text Editor (Command Pattern) ──────────\n")

editor.execute(editor.insert(0, "Hello"))
editor.execute(editor.insert(5, ", World"))
editor.execute(editor.insert(12, "!"))
editor.execute(editor.delete(5, 7))

print("\n── Undo ×3 ────────────────────────────────\n")
editor.undo()
editor.undo()
editor.undo()

print("\n── Redo ×2 ────────────────────────────────\n")
editor.redo()
editor.redo()

print("\nFinal content: \"{editor.get()}\"")
